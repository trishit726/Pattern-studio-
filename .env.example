# Copy this file to `.env` and fill in ONE provider. `.env` is gitignored.
# The render server uses these for the AI "brand-from-a-prompt" and script features.

# Pick a provider: gemini | vertex | anthropic
CLAUDE_PROVIDER=gemini

# --- Option A: Google Gemini (free) -----------------------------------------
# Get a free key at https://aistudio.google.com  (→ "Get API key")
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Option B: Claude on Google Vertex AI (uses GCP credits; gcloud ADC) ------
# Requires Vertex AI API enabled + Claude model quota granted on the project,
# and `gcloud auth application-default login`.
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=global
# CLAUDE_MODEL=claude-opus-4-8

# --- Option C: first-party Anthropic Claude ---------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: ComfyUI endpoint for the experimental AI watercolour pass.
# COMFY_URL=http://127.0.0.1:8188
