    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        background: #000;
      }
      body {
        font-family: "Inter", sans-serif;
        color: #111111;
        -webkit-font-smoothing: antialiased;
      }

      /* Sized root as required by the technical contract */
      #root {
        position: relative;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        background: #111111; /* Dark background */
      }

      .scene {
        position: absolute;
        top: 0;
        left: 0;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
      }

      /* Scene 1: Minimalist Japanese Line-Art */
      #scene1 {
        z-index: 1;
        background: #111111;
      }

      /* Massive red curved shape (circle) on the left/center */
      .red-circle {
        position: absolute;
        width: 1450px;
        height: 1450px;
        background: #F74026; /* Signature Red */
        border-radius: 50%;
        left: -350px;
        top: -185px;
        z-index: 1;
      }

      /* Line art SVG */
      .line-art {
        position: absolute;
        inset: 0;
        width: 1920px;
        height: 1080px;
        z-index: 2;
      }

      /* Set up stroke dashes for SVG path drawing */
      .capsule, .s2-capsule {
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
      }
      circle[id^="c"], circle[id^="s2-c"] {
        stroke-dasharray: 2000;
        stroke-dashoffset: 2000;
      }

      /* Stylized SVG character outlines */
      .text-container {
        display: flex;
        flex-direction: row;
        gap: 15px;
        z-index: 5;
        position: absolute;
        left: 360px;
        top: 500px;
      }
      .char-svg {
        overflow: visible;
      }
      .char-path {
        stroke-dasharray: 600;
        stroke-dashoffset: 600;
      }

      /* Scene 2: Connections & New Value */
      #scene2 {
        z-index: 2;
        background: #111111;
        opacity: 0;
      }

      /* Outro sub-composition slot */
      #logo-outro {
        position: absolute;
        top: 0;
        left: 0;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        z-index: 3;
      }

      .red-shape-s2 {
        position: absolute;
        width: 1200px;
        height: 1200px;
        background: #F74026;
        border-radius: 50%;
        right: -300px;
        bottom: -300px;
        z-index: 1;
      }

      .s2-text-container {
        display: flex;
        flex-direction: column;
        gap: 24px;
        font-family: "Noto Sans JP", sans-serif;
        color: #FFFFFF;
        font-size: 60px;
        font-weight: 300;
        letter-spacing: 5px;
        line-height: 1.4;
        text-align: left;
        position: absolute;
        left: 200px;
        top: 450px;
        z-index: 5;
      }

      .s2-line2 {
        color: #F74026;
        font-weight: 700;
      }

      /* Grain overlay over the whole composition */
      .grain-overlay {
        position: absolute;
        inset: 0;
        z-index: 100;
        background: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)"/%3E%3C/svg%3E');
        opacity: 0.055;
        mix-blend-mode: overlay;
      }
    </style>
  </head>
