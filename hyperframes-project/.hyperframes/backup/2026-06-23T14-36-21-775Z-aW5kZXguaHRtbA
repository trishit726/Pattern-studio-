          <!-- Concentric circles -->
          <circle data-hf-id="hf-38tg" id="s2-c1" cx="960" cy="540" r="300" stroke="rgba(255, 255, 255, 0.15)" stroke-width="2" stroke-dasharray="4,8" fill="none" />
