    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });

      tl.set(".red-circle", { x: -1400, data: "hf-hold" }, 0);

      // --- SCENE 1 ANIMATIONS (0.0s to 8.2s) ---
      // Entrance animations for Scene 1 (starting at 0.2s to avoid t=0)
      tl.to(".red-circle", {
            keyframes: { "0%": { x: -1400, scale: 0.7 }, "100%": { x: 0, scale: 1 }, easeEach: "power4.out" },
            duration: 1.3,
            ease: "none"
      }, 0.2);

      tl.from(".capsule", { strokeDashoffset: 1000, duration: 1.2, ease: "power3.out", stagger: 0.25 }, 0.4);
      tl.from("circle[id^='c']", { strokeDashoffset: 2000, duration: 1.4, ease: "power2.out", stagger: 0.15 }, 0.6);
      tl.from("line", { scaleX: 0, transformOrigin: "left center", duration: 1.0, ease: "power2.out", stagger: 0.1 }, 0.5);

      // SVG character outline drawing
      tl.to(".char-path.char-1", { strokeDashoffset: 0, duration: 0.8, ease: "power2.out" }, 1.2);
      tl.to(".char-path.char-2", { strokeDashoffset: 0, duration: 0.8, ease: "power2.out" }, 1.5);
      tl.to(".char-path.char-3", { strokeDashoffset: 0, duration: 0.8, ease: "power2.out" }, 1.8);
      tl.to(".char-path.char-4", { strokeDashoffset: 0, duration: 0.8, ease: "power2.out" }, 2.1);
      tl.to(".char-path.char-5", { strokeDashoffset: 0, duration: 0.8, ease: "power2.out" }, 2.4);

      // Ambient drifts during Scene 1 hold (start after entrance completes at 1.5s)
      tl.to(".red-circle", { y: "+=25", x: "+=15", scale: 1.03, duration: 6.5, ease: "sine.inOut" }, 1.5);
      tl.to("#c1", { rotation: 45, transformOrigin: "center center", duration: 6.5, ease: "sine.inOut" }, 1.5);
      tl.to("#c3", { rotation: -30, transformOrigin: "center center", duration: 6.5, ease: "sine.inOut" }, 1.5);
      tl.to(".capsule", { y: "-=10", x: "+=10", duration: 6.5, ease: "sine.inOut", stagger: 0.1 }, 1.5);

      // --- TRANSITION 1: Push Slide at 8.0s (duration: 0.6s) ---
      // Scene 1 goes out (left), Scene 2 pushes in (from right)
      tl.to("#scene1", { x: -1920, duration: 0.6, ease: "power3.inOut" }, 8.0);
      tl.fromTo("#scene2", { x: 1920, opacity: 1 }, { x: 0, duration: 0.6, ease: "power3.inOut" }, 8.0);

      // --- SCENE 2 ANIMATIONS (8.0s to 16.5s) ---
      // Entrance animations for Scene 2
      tl.from(".red-shape-s2", { x: 1200, y: 1200, scale: 0.7, duration: 1.4, ease: "power3.out" }, 8.3);

      tl.from(".s2-capsule", { strokeDashoffset: 1000, duration: 1.2, ease: "power3.out", stagger: 0.2 }, 8.5);
      tl.from("circle[id^='s2-c']", { strokeDashoffset: 2000, duration: 1.4, ease: "power2.out", stagger: 0.15 }, 8.7);

      tl.from(".s2-line1", { y: 60, opacity: 0, duration: 0.8, ease: "power3.out" }, 8.9);
      tl.from(".s2-line2", { y: 40, opacity: 0, duration: 0.7, ease: "power2.out" }, 9.2);

      // Ambient drifts during Scene 2 hold (start after S2 entrance completes at 9.8s)
      tl.to(".red-shape-s2", { scale: 1.04, x: "-=20", y: "-=20", duration: 1.7, ease: "sine.inOut" }, 9.8);
      tl.to("#s2-c1", { rotation: -20, transformOrigin: "center center", duration: 1.7, ease: "sine.inOut" }, 9.8);
      tl.to("#s2-c3", { rotation: 15, transformOrigin: "center center", duration: 1.7, ease: "sine.inOut" }, 9.8);
      tl.to(".s2-capsule", { y: "+=5", x: "-=5", duration: 1.7, ease: "sine.inOut", stagger: 0.05 }, 9.8);

      // --- TRANSITION 2: Push Slide at 11.5s (duration: 0.6s) ---
      // Scene 2 goes out (left), Outro pushes in (from right)
      tl.to("#scene2", { x: -1920, duration: 0.6, ease: "power3.inOut" }, 11.5);
      tl.fromTo("#logo-outro", { x: 1920 }, { x: 0, duration: 0.6, ease: "power3.inOut" }, 11.5);

      // Outro fade to black at the end (allowed final scene exit)
      tl.to("#root", { opacity: 0, duration: 0.8, ease: "power2.inOut" }, 15.7);

      window.__timelines["main"] = tl;
